{
  "name": "@soda/friendly-errors-webpack-plugin",
  "version": "1.8.1",
  "description": "Recognizes certain classes of webpack errors and cleans, aggregates and prioritizes them to provide a better Developer Experience",
  "main": "index.js",
  "engines": {
    "node": ">=10.13.0"
  },
  "scripts": {
    "test": "eslint --ignore-pattern \"test/**\" . && jest --testEnvironment node",
    "prepare": "husky"
  },
  "files": [
    "src",
    "index.js"
  ],
  "keywords": [
    "friendly",
    "errors",
    "webpack",
    "plugin"
  ],
  "author": "Geoffroy Warin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sodatea/friendly-errors-webpack-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/sodatea/friendly-errors-webpack-plugin/issues"
  },
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules",
      "src",
      "index.js"
    ]
  },
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.5.4",
    "@babel/plugin-transform-async-to-generator": "^7.5.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "autoprefixer": "^10.0.0",
    "babel-loader": "^8.0.6",
    "css-loader": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-webpack-plugin": "^4.0.1",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "memfs": "^4.0.0",
    "mini-css-extract-plugin": "^2.0.0",
    "postcss-loader": "^7.0.0",
    "sass": "^1.20.1",
    "sass-loader": "^13.0.0",
    "style-loader": "^3.0.0",
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "error-stack-parser": "^2.0.6",
    "string-width": "^4.2.3",
    "strip-ansi": "^6.0.1"
  }
}
