{
  "root": true,
  "env": {
    "browser": true,
    "commonjs": true,
    "es2022": true,
    "jest": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    // http://eslint.org/docs/rules/
    "no-unused-expressions": "warn",
    "no-unused-labels": "warn",
    "no-unused-vars": ["warn", { "vars": "local", "args": "none" }]
  }
}
